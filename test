
# ── Create outputs ──
def create_skin_nonskin_output(img, mask):

    # Skin only (others black)
    skin_only = img.copy()
    skin_only[mask == 0] = [0, 0, 0]

    # Combined (skin = color, non-skin = grayscale)
    grey = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)
    grey = cv2.cvtColor(grey, cv2.COLOR_GRAY2RGB)

    combined = grey.copy()
    combined[mask == 1] = img[mask == 1]

    return skin_only, combined


# ── Show results for 5 images ──
num_images = min(5, len(image_files))

plt.figure(figsize=(22, 5 * num_images))
plt.suptitle("Skin Detection Results", fontsize=16)

for i in range(num_images):

    # Load image
    img_path = os.path.join(skin_images, image_files[i])
    img = load_image(img_path)

    # Load ground truth (if exists)
    name = os.path.splitext(image_files[i])[0]
    gt = None
    for ext in ['.png', '.jpg', '.jpeg']:
        path = os.path.join(ground_truth_images, name + ext)
        if os.path.exists(path):
            gt = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
            break

    # Detect skin
    mask = detect_skin(img, skinMean, skinCovInv, THRESHOLD)

    # Create outputs
    skin_only, combined = create_skin_nonskin_output(img, mask)

    # Count pixels
    total = mask.size
    skin_pixels = np.sum(mask == 1)
    percent = round((skin_pixels / total) * 100, 1)

    # ── Plot (5 columns) ──
    
    # Original
    plt.subplot(num_images, 5, i*5 + 1)
    plt.imshow(img)
    plt.title("Original")
    plt.axis('off')

    # Mask
    plt.subplot(num_images, 5, i*5 + 2)
    plt.imshow(mask * 255, cmap='gray')
    plt.title(f"Mask ({percent}%)")
    plt.axis('off')

    # Skin only
    plt.subplot(num_images, 5, i*5 + 3)
    plt.imshow(skin_only)
    plt.title("Skin Only")
    plt.axis('off')

    # Combined
    plt.subplot(num_images, 5, i*5 + 4)
    plt.imshow(combined)
    plt.title("Skin Color + Grey BG")
    plt.axis('off')

    # Ground truth
    plt.subplot(num_images, 5, i*5 + 5)
    if gt is not None:
        plt.imshow(gt, cmap='gray')
        plt.title("Ground Truth")
    else:
        plt.text(0.5, 0.5, "No GT", ha='center', va='center')
    plt.axis('off')


