import os
import cv2
import numpy as np

all_skin_x = []  # x chromaticity of skin pixels
all_skin_y = []  # y chromaticity of skin pixels

print("Collecting skin pixel chromaticity values...\n")

for filename in cropped_files:
    path = os.path.join(skin_cropped_images, filename)
    img = cv2.imread(path)
    if img is None:
        print("  Could not load:", filename)
        continue

    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    # Convert to chromaticity
    x, y = convert_to_chromaticity(img)

    # Flatten and add to the lists
    all_skin_x.append(x.flatten())
    all_skin_y.append(y.flatten())

# Combine all arrays into one
all_skin_x = np.concatenate(all_skin_x)
all_skin_y = np.concatenate(all_skin_y)

# Remove black pixels (0,0)
mask = (all_skin_x > 0) | (all_skin_y > 0)
all_skin_x = all_skin_x[mask]
all_skin_y = all_skin_y[mask]

print("Total skin pixels collected:", len(all_skin_x))
print("\nSample skin pixels:")
for i in range(5):
    print(f"  Pixel {i+1}: x = {all_skin_x[i]:.4f}, y = {all_skin_y[i]:.4f}")